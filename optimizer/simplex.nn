/*
Solve: 
        c .* x        c, x .el <R>^N
Subject to: 
        A .* x < b    x .el <R>^N .& b .el <R>^M
        x >= 0.0
*/


const <R> epsilon = 1.0e-14

<SimplexResult> .extends <Enums>{0} {
    SOLVED,
    UNBOUNDED,
    UNFEASABLE
}


<simplex_travel> |-> <Vect<R>,<SimplexResult>,<R>> :: (Matrix<R> A,Vect<Z> columns,<Z> &pivot_column,Vect<Z> z_vars,Vect<Z> slack_vars)
// The final phase of the simplex method
// seeking to make the first column of the matrix 
// the bearer of optimal variable values
//
func simplex_travel(A, columns, pivot_column, z_vars, slack_vars) {
    <<simplex_travel>|->> optimal = (UNFEASABLE,null,0)        // the type that this method returns 
    .forever {
        .if ( (simplex_column_test(A, 0, columns, pivot_column)).<B> ) {  // one pairs,triples, ... .first synonum for [0] ... .<B> as the first bool
            optimal = (A[..,0],SOLVED,A[0,0])
            break
        } .else {
            <Z> pivot_row = pivot_search(A,pivot_column)
            .if ( pivot_row == 0 ) {
                optimal = (UNBOUNDED,null,0)
                break
            } .else {
                pivot_exchange(A,pivot_row,pivot_column)
                swap(z_vars[pivot_column-1],slack_vars[pivot_row-1])
            }
        }
    }
    :)-> optimal
}


<simplex_column_test> |-> <<B>,<R>> :: (Matrix<R> A,<Z> row,Vect<Z> columns, <Z> &pivot_column)
// seek a column that has the 
func simplex_column_test(A, row, columns, pivot_column) {
    <B> passed = true
    <R> bmax = 0.0
    .if ( !(columns.empty()) ) {
        <Z> k = columns.start() // iterator interal to vector 
        pivot_column = k        // 
        bmax = A[row,k]   // initial value
        .while ( k = columns.next() ) { // update iterator with call to vector (but if k++ then compile this call)
            let a_rk = A[row,k]         // possible update
            (bmax, pivot_column) = ((a_rk - bmax) > 0.0) ? (a_rk,k) : .no_change   // .no_change -- dont update vars 
        }
        passed = (bmax <= epsilon)
    }
    :)-> (passed,bmax)
}


<simplex_column_fabs_test> |-> <<B>,<R>> :: (Matrix<R> A,<Z> row,Vect<Z> columns, <Z> &pivot_column)
//
func simplex_column_fabs_test(A, row, columns, pivot_column) {
    <B> passed = true
    <R> bmax = 0.0
    .if ( !(columns.empty()) ) {
        <Z> k = columns.start()
        pivot_column = k
        bmax = A[row,k]   // initial value
        .while ( k = columns.next() ) {
            let a_rk = A[row,k]         // possible update
            (bmax, pivot_column) = (((fabs(a_rk) - fabs(bmax)) > 0.0) ? (a_rk,k) : .no_change
        }
        passed = (bmax <= epsilon)
    }
    :)-> (passed,bmax)
}



<pivot_search> |-> <Z> :: (Matrix<R> A,<Z> pivot_column)
//
func pivot_search(A,pivot_column) {
    <Z> row = 0
    <Z> kp = pivot_column + 1
    //
    Z<[,]> i = [1,A.M]
    .for up i ( .with <Z> j = i+1 )  {
        .if ( A[j,kp] < -epsilon ) .break
    }
    //
    .if ( i.beyond_last() ) {    // i > A.M
        :)-> 0
    } .else {
        row = i + 1
        //
        <R> q1 = -A[row,1]/A[row,kp];
        //
        Z<[,]> i = [row,A.M]
        .for up i ( .with <Z> l = i+1 )  {
            .if ( A[j,kp] < -epsilon ) {
                <R> q = -A[l,1]/A[l,kp];
                (row,q1) = (q .< q1) ? (i+1,q) : .no_change
                .<?.else .if ( q1 == q ) {
                    Z<[,]> k = [1,A.N]
                    <R> q0, qp
                    .for up k ( .with <Z> k1 = k + 1 ) {
                        qp = -A[row,k1]/A[row,kp];
                        q0 = -A[l,k1]/A[l,kp];
                        .if (q0 != qp) break;
                    }
                    .if (q0 < qp) row=(i+1);
                }
            }
        }
    }
    //
    :)-> row
}



<pivot_search_PY> |-> <Z> :: (Matrix<R> A,<Z> pivot_column)
//
func pivot_search_PY(A,pivot_column) {
    <Z> row = 0
    <Z> kp = pivot_column + 1
    //
    Z<[,]> i = [1,A.M]
    //
    <Z> i_hat = .first up i { <Z> | .with j = i+1; A[j,kp] < -epsilon }
    //
    .if ( i.beyond_last() ) {    // i > A.M
        :)-> 0
    } .else {
        row = i_hat + 1
        //
        <R> q1 = -A[row,1]/A[row,kp];
        //
        Z<[,]> i = [row,A.M]
        .update (row) .by
        .looping up i ( .with <Z> l = i+1 )  {
            .if ( A[j,kp] < -epsilon ) {
                <R> q = -A[l,1]/A[l,kp];
                (row,q1) = (q .< q1) ? (l,q) : .no_change
                .<?.else .if ( q1 == q ) {
                    Z<[,]> k = [1,A.N]
                    <R,R> (q0, qp) = .first up k { <R,R> (q0,qp) | q0 != qp
                                                    .with k1 = k+1
                                                    .where {
                                                        qp = -A[row,k1]/A[row,kp];
                                                        q0 = -A[l,k1]/A[l,kp];
                                                    }
                                                }
                    .if (q0 < qp) row = l;
                }
            }
        }
    }
    //
    :)-> row
}



<pivot_exchange> |-> <> :: (Matrix<R> A,<Z> pivot_row,<Z> pivot_column)
//
func pivot_exchange(A,pivot_row,pivot_column) {
    //
    const <R> pivot = 1.0/A[pivot_row,pivot_column];   // assume offsets are figured
    Z<[,]> i = [1,A.M]
    Z<[,]> j = [1,A.N]
    //
    .for up i ( .skip pivot_row ) {        // pivot elimination  // reset assumed otherwise say so
        let row_mult = (A[i,pivot_column] *= pivot);
        .for up j ( .skip pivot_column ) {
            A[i,j] -= A[pivot_row,j]*row_mult;
        }
    }
    //
    .for up j ( .skip pivot_column ) {
        A[pivot_row,j] *= -pivot;
    }
    //
    A[pivot_row,pivot_column] = pivot
}




<pivot_exchange_PY> |-> <> :: (Matrix<R> A,<Z> pivot_row,<Z> pivot_column)
//
func pivot_exchange_PY(A,pivot_row,pivot_column) {
    //
    const <R> pivot = 1.0/A[pivot_row,pivot_column];   // assume offsets are figured
    Z<[,]> i = [1,A.M].skip(pivot_row)
    Z<[,]> j = [1,A.N].skip(pivot_column)
    //
    A[i .up,pivot_column] *= pivot              // implicit in place map operation
    A[i .up,j .up] -= A[pivot_row,j]*A[i,pivot_column];
    //
    A[pivot_row,j .up] *= -pivot;
    //
    A[pivot_row,pivot_column] = pivot
}




